<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dtos="clr-namespace:MauiApp1.AppLogic.DTOs"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             xmlns:dxg="clr-namespace:DevExpress.Maui.DataGrid;assembly=DevExpress.Maui.DataGrid"
             xmlns:dxe="clr-namespace:DevExpress.Maui.Editors;assembly=DevExpress.Maui.Editors"
             x:DataType="viewmodels:ProductManagePageViewModel"
             x:Class="MauiApp1.ProductManagePage"
             Title="Product Manage Page">
        <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add Product" Command="{Binding GoToAddProductPageCommand}" />
        </ContentPage.ToolbarItems>

    <!-- ROOT GRID -->
    <Grid>

        <!-- MAIN CONTENT GRID -->
        <Grid RowDefinitions="Auto, Auto, *">

            <!-- Title -->
            <Label Grid.Row="0" 
                   Text="Product Management" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   Padding="20,10" 
                   TextColor="{StaticResource Primary}"/>

            <!-- SEARCH BAR -->
            <dxe:TextEdit Grid.Row="1"
                          PlaceholderText="Search products..."
                          Text="{Binding SearchText, Mode=TwoWay}"
                          BoxMode="Filled"
                          CornerRadius="10"
                          Margin="20,0,20,10"
                          StartIcon="search_icon.png" 
                          ClearIconVisibility="Auto"/>

            <RefreshView Grid.Row="2"
                         IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding LoadProductCommand}">

                <dxg:DataGridView ItemsSource="{Binding Products}"
                                  SelectionMode="Single"
                                  SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                                  AllowSort="True"
                                  IsColumnHeaderVisible="True"
                                  RowHeight="80"
                                  Tap="OnDataGridTap">

                    <dxg:DataGridView.Columns>



                        <!-- Name Column -->
                        <dxg:TextColumn FieldName="Name" 
                                        Caption="Product Name" 
                                        Width="*"/>

                        <!-- Price Column -->
                        <dxg:TextColumn FieldName="Price" 
                                        Caption="Price" 
                                        Width="100" 
                                        DisplayFormat="C"/>

                        <!-- Status Column -->
                        <dxg:TemplateColumn Caption="Status" Width="90">
                            <dxg:TemplateColumn.DisplayTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="#E8F5E9" 
                                            StrokeShape="RoundRectangle 10" 
                                            StrokeThickness="0"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            Padding="10,4">
                                        <Label Text="Active" 
                                               TextColor="#2E7D32" 
                                               FontSize="11" 
                                               FontAttributes="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </dxg:TemplateColumn.DisplayTemplate>
                        </dxg:TemplateColumn>

                    </dxg:DataGridView.Columns>

                    <dxg:DataGridView.EndSwipeItems>
                        <dxg:SwipeItem Caption="Delete"
                                       BackgroundColor="{StaticResource Error}"
                                       Command="{Binding DeleteProductCommand}"/>
                    </dxg:DataGridView.EndSwipeItems>

                </dxg:DataGridView>
            </RefreshView>
        </Grid>

        <!-- POPUP OVERLAY -->
        <Grid IsVisible="{Binding IsPopupOpen}"
              BackgroundColor="{StaticResource PopupOverlayColor}">
            <Border HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Padding="20"
                    WidthRequest="300"
                    BackgroundColor="White"
                    StrokeShape="RoundRectangle 10"
                    Stroke="{StaticResource Primary}"
                    StrokeThickness="2">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.5" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="15">

                    <Label Text="Product Details"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource Primary}"
                           HorizontalOptions="Center"/>

                    <Border StrokeShape="Ellipse"
                            Stroke="LightGray"
                            StrokeThickness="2"
                            BackgroundColor="#F5F5F5"
                            HeightRequest="120"
                            WidthRequest="120"
                            HorizontalOptions="Center">
                        <Image Source="{Binding SelectedProduct.ImageUrl}"
                               Aspect="AspectFill"
                               HeightRequest="120"
                               WidthRequest="120">
                            <Image.Clip>
                                <EllipseGeometry Center="60,60" RadiusX="60" RadiusY="60"/>
                            </Image.Clip>
                        </Image>
                    </Border>

                    <!-- ScrollView for editable content if needed, using VSL for now -->
                    <VerticalStackLayout Spacing="10">
                        
                        <!-- Name -->
                        <dxe:TextEdit LabelText="Name" 
                                      Text="{Binding SelectedProduct.Name}" 
                                      IsReadOnly="{Binding IsNotEditing}"
                                      HelpText="Double tap to edit">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- Description -->
                        <dxe:TextEdit LabelText="Description" 
                                      Text="{Binding SelectedProduct.Description}" 
                                      IsReadOnly="{Binding IsNotEditing}">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- Price -->
                        <dxe:TextEdit LabelText="Price" 
                                      Text="{Binding SelectedProduct.Price, StringFormat='{0:N0}'}" 
                                      IsReadOnly="{Binding IsNotEditing}"
                                      Keyboard="Numeric">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- Stock -->
                        <dxe:TextEdit LabelText="Stock Quantity" 
                                      Text="{Binding SelectedProduct.StockQuantity}" 
                                      IsReadOnly="{Binding IsNotEditing}"
                                      Keyboard="Numeric">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- Status -->
                        <dxe:TextEdit LabelText="Status" 
                                      Text="{Binding SelectedProduct.Status}" 
                                      IsReadOnly="{Binding IsNotEditing}">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- CreatedAt (ReadOnly) -->
                        <Label Text="{Binding SelectedProduct.CreatedAt, StringFormat='Created: {0:dd/MM/yyyy}'}" 
                               TextColor="Gray" FontSize="12" HorizontalOptions="Center"/>
                        
                        <!-- UpdatedAt (ReadOnly) -->
                        <Label Text="{Binding SelectedProduct.UpdatedAt, StringFormat='Updated: {0:dd/MM/yyyy}'}" 
                               TextColor="Gray" FontSize="12" HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                    <!-- BUTTONS -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        
                        <!-- Close Button (Visible when NOT Editing) -->
                        <Button Grid.Column="0" Grid.ColumnSpan="2"
                                Text="Close"
                                Command="{Binding ClosePopupCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                IsVisible="{Binding IsNotEditing}"/>

                        <!-- Cancel Button (Visible when Editing) -->
                        <Button Grid.Column="0"
                                Text="Cancel"
                                Command="{Binding CancelEditCommand}"
                                BackgroundColor="#E0E0E0"
                                TextColor="Black"
                                IsVisible="{Binding IsEditing}"/>

                        <!-- Save Button (Visible when Editing) -->
                        <Button Grid.Column="1"
                                Text="Save"
                                Command="{Binding SaveProductCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                IsVisible="{Binding IsEditing}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>