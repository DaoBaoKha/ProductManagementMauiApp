<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             xmlns:enums="clr-namespace:MauiApp1.AppLogic.Enums"
             xmlns:behaviors="clr-namespace:MauiApp1.Behaviors" 
             xmlns:controls="clr-namespace:MauiApp1.Controls"
             xmlns:dxcore="clr-namespace:DevExpress.Maui.Core;assembly=DevExpress.Maui.Core"
             xmlns:dxe="clr-namespace:DevExpress.Maui.Editors;assembly=DevExpress.Maui.Editors"
             x:Class="MauiApp1.AddUserPage"
             x:DataType="viewmodels:AddUserPageViewModel"
             Title="Add New User">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center">
            <Image Source="dotnet_bot.png" HeightRequest="80" />
            <Label Text="Input User Information" FontSize="20" FontAttributes="Bold"/>
        </VerticalStackLayout>

        <VerticalStackLayout Grid.Row="1" Spacing="15" VerticalOptions="Center">

            <dxe:TextEdit LabelText="Name" 
                          Text="{Binding Name, Mode=TwoWay}" 
                          PlaceholderText="Input Name"
                          BoxMode="Outlined"
                          CornerRadius="10"
                          BorderColor="{StaticResource Primary}"
                          FocusedBorderColor="{StaticResource Primary}"/>

            <dxe:TextEdit LabelText="Email"
                          Text="{Binding Email, Mode=TwoWay}" 
                          PlaceholderText="Input Email" 
                          Keyboard="Email"
                          BoxMode="Outlined"
                          CornerRadius="10"
                          BorderColor="{StaticResource Primary}"
                          FocusedBorderColor="{StaticResource Primary}"/>

            <dxe:ComboBoxEdit LabelText="Gender"
                              SelectedItem="{Binding Gender, Mode=TwoWay}"
                              BoxMode="Outlined"
                              CornerRadius="10"
                              BorderColor="{StaticResource Primary}"
                              FocusedBorderColor="{StaticResource Primary}"
                              IsFilterEnabled="False">
                <dxe:ComboBoxEdit.ItemsSource>
                    <x:Array Type="{x:Type enums:Gender}">
                        <enums:Gender>Male</enums:Gender>
                        <enums:Gender>Female</enums:Gender>
                        <enums:Gender>Other</enums:Gender>
                        <enums:Gender>PreferNotToSay</enums:Gender>
                    </x:Array>
                </dxe:ComboBoxEdit.ItemsSource>
            </dxe:ComboBoxEdit>

        </VerticalStackLayout>

        <dxcore:DXButton Grid.Row="2" Content="Save" 
                         Command="{Binding SaveUserCommand}"
                         HeightRequest="50" CornerRadius="25" Margin="0,0,0,10">
            <dxcore:DXButton.Triggers>
                <DataTrigger TargetType="dxcore:DXButton" 
                             Binding="{Binding IsFormValid}" 
                             Value="False">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="BackgroundColor" Value="{StaticResource Gray200}" />
                    <Setter Property="TextColor" Value="{StaticResource Gray500}" />
                </DataTrigger>
                <DataTrigger TargetType="dxcore:DXButton" 
                             Binding="{Binding IsFormValid}" 
                             Value="True">
                    <Setter Property="IsEnabled" Value="True" />
                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                    <Setter Property="TextColor" Value="White" />
                </DataTrigger>
            </dxcore:DXButton.Triggers>
        </dxcore:DXButton>

        <controls:ToastNotification x:Name="ToastNotificationControl" Grid.RowSpan="3" VerticalOptions="Start" />
    </Grid>
</ContentPage>