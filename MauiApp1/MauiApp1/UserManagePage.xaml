<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dtos="clr-namespace:MauiApp1.AppLogic.DTOs"
             xmlns:enums="clr-namespace:MauiApp1.AppLogic.Enums"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             
             xmlns:dxg="clr-namespace:DevExpress.Maui.DataGrid;assembly=DevExpress.Maui.DataGrid"
             xmlns:dxe="clr-namespace:DevExpress.Maui.Editors;assembly=DevExpress.Maui.Editors"
             xmlns:dxco="clr-namespace:DevExpress.Maui.Controls;assembly=DevExpress.Maui.Controls"
             xmlns:dxcore="clr-namespace:DevExpress.Maui.Core;assembly=DevExpress.Maui.Core"
             
             x:Class="MauiApp1.UserManagePage"
             x:DataType="viewmodels:UserManagePageViewModel"
             Title="User Management"
             BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add User" Command="{Binding GoToAddUserPageCommand}" />
    </ContentPage.ToolbarItems>

    <Grid>

        <Grid RowDefinitions="Auto, Auto, *">

            <Label Grid.Row="0" 
                   Text="User Management" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   Padding="20,10,20,5" 
                   TextColor="{StaticResource Primary}"/>

            <dxe:TextEdit Grid.Row="1"
                          PlaceholderText="Search users..."
                          Text="{Binding SearchText, Mode=TwoWay}"
                          BoxMode="Filled"
                          CornerRadius="10"
                          Margin="20,0,20,10"
                          StartIcon="search_icon.png" 
                          ClearIconVisibility="Auto"/>

            <RefreshView Grid.Row="2"
                         IsRefreshing="{Binding IsRefreshing}"
                         Command="{Binding LoadUserCommand}">

                <dxg:DataGridView ItemsSource="{Binding Users}"
                                  SelectionMode="Single"
                                  SelectedItem="{Binding SelectedUser, Mode=TwoWay}"
                                  AllowSort="True"
                                  IsColumnHeaderVisible="True"
                                  RowHeight="70"
                                  Tap="OnDataGridTap">

                    <dxg:DataGridView.Columns>



                        <!-- Name Column -->
                        <dxg:TextColumn FieldName="FullName" 
                                        Caption="Name" 
                                        Width="150"/>

                        <!-- Email Column -->
                        <dxg:TextColumn FieldName="Email" 
                                        Caption="Email" 
                                        Width="*"/>


                        <dxg:TemplateColumn Caption="Status" Width="80">
                            <dxg:TemplateColumn.DisplayTemplate>
                                <DataTemplate x:DataType="dtos:UserDto">
                                    <Border BackgroundColor="#E8F5E9" 
                                            StrokeShape="RoundRectangle 10" 
                                            StrokeThickness="0"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"
                                            Padding="10,4"> 
                                        <Label Text="Active" 
                                   TextColor="#2E7D32" 
                                   FontSize="11" 
                                   FontAttributes="Bold"/>
                                    </Border>
                                </DataTemplate>
                            </dxg:TemplateColumn.DisplayTemplate>
                        </dxg:TemplateColumn>

                    </dxg:DataGridView.Columns>
                    
                    <dxg:DataGridView.EndSwipeItems>
                        <dxg:SwipeItem Caption="Delete"
                                       BackgroundColor="{StaticResource Error}"
                                       Command="{Binding DeleteUserCommand}"/>
                    </dxg:DataGridView.EndSwipeItems>

                </dxg:DataGridView>
            </RefreshView>
        </Grid>

        <dxco:DXPopup IsOpen="{Binding IsPopupOpen}"
                      AllowScrim="True"
                      ScrimColor="{StaticResource PopupOverlayColor}">

            <Border WidthRequest="350"
                    StrokeShape="RoundRectangle 15"
                    BackgroundColor="White"
                    Stroke="{StaticResource Primary}"
                    StrokeThickness="2"
                    Padding="20">

                <VerticalStackLayout Spacing="15">
                    <Label Text="User Details" FontSize="22" FontAttributes="Bold" 
                           TextColor="{StaticResource Primary}" HorizontalOptions="Center"/>

                    <Image Source="{Binding SelectedUser.AvatarUrl}" 
                           HeightRequest="100" 
                           WidthRequest="100" 
                           HorizontalOptions="Center"
                           Aspect="AspectFill">
                        <Image.Clip>
                            <EllipseGeometry Center="50,50" RadiusX="50" RadiusY="50"/>
                        </Image.Clip>
                    </Image>

                    <VerticalStackLayout Spacing="10">
                        
                        <!-- Full Name -->
                        <dxe:TextEdit LabelText="Full Name"
                                      Text="{Binding SelectedUser.FullName}"
                                      IsReadOnly="{Binding IsNotEditing}"
                                      HelpText="Double tap to edit">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- Email -->
                        <dxe:TextEdit LabelText="Email"
                                      Text="{Binding SelectedUser.Email}"
                                      IsReadOnly="{Binding IsNotEditing}"
                                      Keyboard="Email">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- Username -->
                        <dxe:TextEdit LabelText="Username"
                                      Text="{Binding SelectedUser.Username}"
                                      IsReadOnly="{Binding IsNotEditing}">
                            <dxe:TextEdit.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                            </dxe:TextEdit.GestureRecognizers>
                        </dxe:TextEdit>

                        <!-- Date Of Birth -->
                        <Grid>
                            <dxe:DateEdit LabelText="Date Of Birth"
                                          Date="{Binding SelectedUser.DateOfBirth}"
                                          IsReadOnly="{Binding IsNotEditing}"
                                          DisplayFormat="dd/MM/yyyy"/>
                            
                            <!-- Overlay for gesture when not editing -->
                            <Grid BackgroundColor="Transparent" IsVisible="{Binding IsNotEditing}">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Grid>

                        <!-- Gender -->
                        <Grid>
                            <dxe:ComboBoxEdit LabelText="Gender"
                                              SelectedItem="{Binding SelectedUser.Gender}"
                                              IsReadOnly="{Binding IsNotEditing}"
                                              IsFilterEnabled="False">
                                <dxe:ComboBoxEdit.ItemsSource>
                                    <x:Array Type="{x:Type enums:Gender}">
                                        <enums:Gender>Male</enums:Gender>
                                        <enums:Gender>Female</enums:Gender>
                                        <enums:Gender>Other</enums:Gender>
                                        <enums:Gender>PreferNotToSay</enums:Gender>
                                    </x:Array>
                                </dxe:ComboBoxEdit.ItemsSource>
                            </dxe:ComboBoxEdit>
                            
                             <!-- Overlay for gesture when not editing -->
                            <Grid BackgroundColor="Transparent" IsVisible="{Binding IsNotEditing}">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding EnableEditModeCommand}" NumberOfTapsRequired="2"/>
                                </Grid.GestureRecognizers>
                            </Grid>
                        </Grid>

                        <!-- ID (ReadOnly) -->
                        <Label Text="{Binding SelectedUser.Id, StringFormat='ID: {0}'}" 
                               TextColor="Gray" FontSize="12" HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                    <!-- BUTTONS -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        
                        <!-- Close Button (Visible when NOT Editing) -->
                        <Button Grid.Column="0" Grid.ColumnSpan="2"
                                Text="Close"
                                Command="{Binding ClosePopupCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                IsVisible="{Binding IsNotEditing}"/>

                        <!-- Cancel Button (Visible when Editing) -->
                        <Button Grid.Column="0"
                                Text="Cancel"
                                Command="{Binding CancelEditCommand}"
                                BackgroundColor="#E0E0E0"
                                TextColor="Black"
                                IsVisible="{Binding IsEditing}"/>

                        <!-- Save Button (Visible when Editing) -->
                        <Button Grid.Column="1"
                                Text="Save"
                                Command="{Binding SaveUserCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                IsVisible="{Binding IsEditing}"/>
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </dxco:DXPopup>

    </Grid>
</ContentPage>