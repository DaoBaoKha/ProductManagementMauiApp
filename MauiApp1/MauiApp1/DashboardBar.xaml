<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             
             xmlns:dxcore="clr-namespace:DevExpress.Maui.Core;assembly=DevExpress.Maui.Core"
             
             x:Class="MauiApp1.DashboardBar"
             x:DataType="viewmodels:DashboardBarViewModel"
             Title="Dashboard"
             BackgroundColor="#F5F5F5">

    <ContentPage.Resources>
        <Style x:Key="DashboardButtonStyle" TargetType="dxcore:DXButton">
            <Setter Property="BackgroundColor" Value="DodgerBlue" />
            <Setter Property="TextColor" Value="White" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HeightRequest" Value="55" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="ButtonType" Value="Filled" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="My Dashboard" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="{StaticResource Primary}"
                   HorizontalOptions="Center"
                   Margin="0,20,0,10" />

            <BoxView HeightRequest="1" Color="LightGray" WidthRequest="100" HorizontalOptions="Center" Margin="0,0,0,30"/>

            <dxcore:DXButton Content="Home" 
                             Command="{Binding HomeCommand}"
                             Style="{StaticResource DashboardButtonStyle}"
                             Icon="dotnet_bot.png"/>

            <dxcore:DXButton Content="Profile" 
                             Command="{Binding ProfileCommand}"
                             Style="{StaticResource DashboardButtonStyle}"
                             Icon="dotnet_bot.png"/>

            <dxcore:DXButton Content="Settings" 
                             Command="{Binding SettingsCommand}"
                             Style="{StaticResource DashboardButtonStyle}"
                             Icon="dotnet_bot.png"/>

            <BoxView HeightRequest="1" Color="LightGray" Margin="10,20" />

            <dxcore:DXButton Content="Logout" 
                             Command="{Binding LogoutCommand}"
                             Style="{StaticResource DashboardButtonStyle}"
                             BackgroundColor="OrangeRed" 
                             Icon="dotnet_bot.png"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>