<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiApp1.ViewModels"
             xmlns:controls="clr-namespace:MauiApp1.Controls"
             xmlns:behaviors="clr-namespace:MauiApp1.Behaviors"
             xmlns:dxcore="clr-namespace:DevExpress.Maui.Core;assembly=DevExpress.Maui.Core"
             xmlns:dxe="clr-namespace:DevExpress.Maui.Editors;assembly=DevExpress.Maui.Editors"
             x:Class="MauiApp1.AddProductPage"
             x:DataType="viewmodels:AddProductPageViewModel"
             Title="Add New Product">
    
    <Grid RowDefinitions="Auto, *, Auto" Padding="20">



        <!-- Header -->
        <VerticalStackLayout Grid.Row="0" Spacing="10" HorizontalOptions="Center">
            <Image Source="dotnet_bot.png" HeightRequest="80" />
            <Label Text="Input Product Information" FontSize="20" FontAttributes="Bold"/>
        </VerticalStackLayout>

        <!-- Form Fields -->
        <ScrollView Grid.Row="1">
            
            <VerticalStackLayout Spacing="15" VerticalOptions="Center">
                
                <!-- Product Name -->
                <dxe:TextEdit LabelText="Product Name" 
                              Text="{Binding Name, Mode=TwoWay}" 
                              PlaceholderText="Enter product name"
                              BoxMode="Outlined"
                              CornerRadius="10"
                              BorderColor="{StaticResource Primary}"
                              FocusedBorderColor="{StaticResource Primary}"/>

                <!-- Description -->
                <dxe:MultilineEdit LabelText="Description" 
                                   Text="{Binding Description, Mode=TwoWay}" 
                                   PlaceholderText="Enter product description"
                                   BoxMode="Outlined"
                                   CornerRadius="10"
                                   BorderColor="{StaticResource Primary}"
                                   FocusedBorderColor="{StaticResource Primary}"/>

                <!-- Price -->
                <dxe:TextEdit LabelText="Price ($)" 
                              Text="{Binding PriceText, Mode=TwoWay}" 
                              PlaceholderText="Enter price (e.g., 19.99)"
                              Keyboard="Numeric"
                              BoxMode="Outlined"
                              CornerRadius="10"
                              BorderColor="{StaticResource Primary}"
                              FocusedBorderColor="{StaticResource Primary}"/>

                <!-- Stock Quantity -->
                <dxe:TextEdit LabelText="Stock Quantity" 
                              Text="{Binding StockText, Mode=TwoWay}" 
                              PlaceholderText="Enter stock quantity"
                              Keyboard="Numeric"
                              BoxMode="Outlined"
                              CornerRadius="10"
                              BorderColor="{StaticResource Primary}"
                              FocusedBorderColor="{StaticResource Primary}"/>

            </VerticalStackLayout>
            
        </ScrollView>

        <!-- Save Button -->
        <dxcore:DXButton Grid.Row="2" 
                         Content="Save Product" 
                         Command="{Binding SaveProductCommand}"
                         HeightRequest="50" 
                         CornerRadius="25" 
                         Margin="0,0,0,10">
            <dxcore:DXButton.Triggers>
                <DataTrigger TargetType="dxcore:DXButton" 
                             Binding="{Binding IsFormValid}" 
                             Value="False">
                    <Setter Property="IsEnabled" Value="False" />
                    <Setter Property="BackgroundColor" Value="{StaticResource Gray200}" />
                    <Setter Property="TextColor" Value="{StaticResource Gray500}" />
                </DataTrigger>
                <DataTrigger TargetType="dxcore:DXButton" 
                             Binding="{Binding IsFormValid}" 
                             Value="True">
                    <Setter Property="IsEnabled" Value="True" />
                    <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
                    <Setter Property="TextColor" Value="White" />
                </DataTrigger>
            </dxcore:DXButton.Triggers>
        </dxcore:DXButton>

        <!-- Toast Notification -->
        <controls:ToastNotification x:Name="ToastNotificationControl" 
                                     Grid.RowSpan="3" 
                                     VerticalOptions="Start" />
    </Grid>
</ContentPage>